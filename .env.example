# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Real AWS development
#
# Copy to .env and fill in your values:
#   cp .env.example .env
#
# .env is gitignored. Never commit real credentials.
# Source before running AWS CLI commands or invoking Lambda handlers locally:
#   source .env
#
# First time? See docs/aws-credentials.md for step-by-step setup of
# ~/.aws/credentials (long-term keys, named profiles, or SSO).
# ─────────────────────────────────────────────────────────────────────────────


# ── AWS credentials ───────────────────────────────────────────────────────────
# Option A: named profile (recommended — credentials stay in ~/.aws/credentials)
# Run once: aws configure --profile data-pipeline-poc
# See: docs/aws-credentials.md — Method 1 (long-term keys) or Method 2 (SSO)
export AWS_PROFILE=data-pipeline-poc

# Option B: explicit keys (uncomment if you can't use profiles)
# export AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxxxxxxxx
# export AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# export AWS_SESSION_TOKEN=                        # required for SSO / assumed roles

export AWS_DEFAULT_REGION=eu-west-3


# ── Terraform ─────────────────────────────────────────────────────────────────
# Avoids editing terraform.tfvars for the password — Terraform reads TF_VAR_*
# automatically. Must satisfy Redshift password rules:
#   8–64 chars, at least one uppercase, one lowercase, one digit.
export TF_VAR_redshift_admin_password=ChangeMe123!

# Optional: override other Terraform variables without editing terraform.tfvars
# export TF_VAR_aws_region=eu-west-3
# export TF_VAR_project_name=data-pipeline


# ── Lambda runtime (needed only when invoking handlers directly, not via AWS) ─
# These are injected automatically by Terraform in the real deployment.
# Fill in after `terraform apply`:
#   echo "export DATA_LAKE_BUCKET=$(cd terraform && terraform output -raw data_lake_bucket)" >> .env
#   echo "export REDSHIFT_WORKGROUP=$(cd terraform && terraform output -raw redshift_workgroup_name)" >> .env
export DATA_LAKE_BUCKET=                           # e.g. data-pipeline-data-lake-123456789012
export REDSHIFT_WORKGROUP=                         # e.g. data-pipeline-wg
export REDSHIFT_DATABASE=dev
